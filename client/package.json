{
  "name": "@alvico/client",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "set EXPO_USE_METRO_WORKSPACE_ROOT=true && expo start --web --clear",
    "clear:metro": "set EXPO_USE_METRO_WORKSPACE_ROOT=true && expo start --web --clear",
    "clean:start": "taskkill /F /IM node.exe 2>nul || echo \"No node processes to kill\" && set EXPO_USE_METRO_WORKSPACE_ROOT=true && npx expo start --web --clear",
    "vercel-build": "cd .. && npm install && cd client && npx expo export --platform web"
  },
  "dependencies": {
    "@alvico/shared": "*",
    "@expo/metro-runtime": "~3.1.3",
    "axios": "^1.6.0",
    "expo": "~50.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-web": "~0.19.13",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/node": "^20.0.0",
    "@types/react": "~18.2.45",
    "@types/react-dom": "~18.2.18",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-preset-expo": "^10.0.2",
    "typescript": "^5.3.3"
  }
}