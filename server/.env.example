# Server Environment Variables

# Port the server runs on
PORT=3001

# n8n Webhook URL for focus session notifications
N8N_WEBHOOK_URL=http://localhost:5678/webhook/alvico-sync

# Node environment (development, production, test)
NODE_ENV=development

# Database path (future: SQLite file location)
DATABASE_PATH=./data/alvico.db

# CORS origin (allow client requests)
CORS_ORIGIN=http://localhost:19006

# Webhook timeout (milliseconds)
WEBHOOK_TIMEOUT=5000
